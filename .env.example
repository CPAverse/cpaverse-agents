# ═══════════════════════════════════════════════════════════════
# CPAverse Tax Prep Agent — Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values.
# NEVER commit the .env file to git.
# ═══════════════════════════════════════════════════════════════

# ── TaxDome ───────────────────────────────────────────────────
TAXDOME_USERNAME=admin@joshmauercpa.com
TAXDOME_PASSWORD=                          # Set securely, never log
TAXDOME_TOTP_SECRET=                       # Base32 TOTP secret from authenticator setup
TAXDOME_LOGIN_URL=https://app.taxdome.com/login

# ── Drake Tax 2025 ────────────────────────────────────────────
DRAKE_2025_USERNAME=                       # Drake login username
DRAKE_2025_PASSWORD=                       # Set securely, rotates every 90 days
DRAKE_2025_TOTP_SECRET=                    # Base32 TOTP secret for 2025 year
DRAKE_2025_SECURITY_QUESTION=              # Security question for password reset
DRAKE_2025_SECURITY_ANSWER=                # Answer to security question
DRAKE_2025_LOGIN_URL=                      # AWS WorkSpace RDP or web URL
DRAKE_2025_LAST_PW_CHANGE=2026-03-30       # Date of last password change (YYYY-MM-DD)

# ── AWS WorkSpace — Virtual Drive ─────────────────────────────
# The AWS WorkSpace maps a virtual drive to TaxDome client folders.
# Agent reads client documents (W-2s, 1099s, etc.) directly from
# the filesystem instead of downloading through TaxDome's browser UI.
TAXDOME_VIRTUAL_DRIVE=                     # e.g., T:\ or /mnt/taxdome/

# ── Google Chat (Admin Notifications Only) ────────────────────
# One-way webhook: agent → Josh Mauer (security alerts, password rotations)
CPAVERSE_GCHAT_WEBHOOK=https://chat.googleapis.com/v1/spaces/AAQAgN8ueP8/messages?key=AIzaSyDdI0hCZtE6vySjMm-WEfRq3CPzqKqqsHI&token=bVxn5g_M9Qep3C9ecvs__dZVDMQGI1GfRLby57qB46Q

# ── GitHub (Activity Logs) ────────────────────────────────────
GITHUB_PAT=                                # Personal Access Token for CPAverse org
GITHUB_REPO=CPAverse/cpaverse-agents
GITHUB_LOG_PATH=logs/daily-activity.md
GITHUB_ARCHIVE_PATH=logs/archive/

# ── Claude API (Report Formatting) ───────────────────────────
ANTHROPIC_API_KEY=                         # For morning report formatting

# ── Firecrawl (Browser Automation) ───────────────────────────
FIRECRAWL_API_KEY=                         # Firecrawl API key for browser automation
FIRECRAWL_BASE_URL=https://api.firecrawl.dev

# ── n8n Cloud ─────────────────────────────────────────────────
N8N_BASE_URL=https://cpaverse.app.n8n.cloud
N8N_API_KEY=                               # n8n API key for workflow management

# ── Agent Configuration ───────────────────────────────────────
CPAVERSE_CONFIG_PATH=                      # Optional path to JSON config file
AGENT_TIMEZONE=America/Chicago             # CT timezone
AGENT_LOG_LEVEL=INFO                       # DEBUG, INFO, WARNING, ERROR
